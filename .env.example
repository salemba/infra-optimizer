# ── LLM ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here
LLM_MODEL=claude-opus-4-6          # any Anthropic model ID

# ── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# ENV=dev                           # enables hot-reload (development only)

# ── Security ──────────────────────────────────────────────────────────────
# API_KEY=change_me                 # unset = no auth (ok behind VPN/private network)
# CORS_ORIGINS=https://grafana.internal,https://dashboard.internal

# ── Storage ───────────────────────────────────────────────────────────────
# STORE_DSN=./data/metrics.duckdb   # unset = in-memory (lost on restart)
#                                   # DuckDB (recommended): ./data/metrics.duckdb
#                                   #   → enables GET /api/metrics/history timeseries queries
#                                   # SQLite (simple):      ./data/reports.db
#                                   # Upgrade path: postgresql://user:pass@host/db

# ── Integrations ──────────────────────────────────────────────────────────
# WEBHOOK_URLS=https://hooks.slack.com/...,https://grafana.internal/api/webhooks/...
PROMETHEUS_ENABLED=true

# ── Input limits ──────────────────────────────────────────────────────────
MAX_METRICS=5000

# ── Rate limiting ─────────────────────────────────────────────────────────
# RATE_LIMIT=10/minute               # applied to POST /api/analyze
# INGEST_RATE_LIMIT=120/minute       # applied to POST /api/metrics (streaming)

# ── Streaming buffer ──────────────────────────────────────────────────────
# BUFFER_SIZE=1000                   # max metric points held before flush required
# SSE_INTERVAL=5                     # seconds between SSE heartbeats / checks

# ── Pipeline timeout ──────────────────────────────────────────────────────
# PIPELINE_TIMEOUT=60                # seconds before HTTP 504 is returned

# ── Thresholds ────────────────────────────────────────────────────────────
# THRESHOLDS_FILE=thresholds.json    # edit thresholds.json to tune detection

# ── Logging ───────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
